# Music generation
ELEVENLABS_API_KEY=
MUBERT_CUSTOMER_ID=
MUBERT_ACCESS_TOKEN=

# Gemini API / Nano Banana 2 image generation and optional SEO copy
GEMINI_API_KEY=
GEMINI_MUSIC_MODEL=lyria-3-pro-preview
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite-preview

# YouTube upload
YOUTUBE_CLIENT_SECRETS=./client_secret.json
YOUTUBE_TOKEN_FILE=./.secrets/youtube-token.json

# Runtime defaults
YMF_WORKDIR=./runs
